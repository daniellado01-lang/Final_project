import cv2
import numpy as np
from ultralytics import YOLO
import joblib
import os
import pandas as pd 
import time
import threading
import wave
import json
import sys

# Ocultar mensajes molestos de pygame
os.environ['PYGAME_HIDE_SUPPORT_PROMPT'] = "hide"
import pygame 
from moviepy import VideoFileClip
from vosk import Model, KaldiRecognizer
import warnings
warnings.filterwarnings('ignore')

print("=== INICIANDO SISTEMA MULTIMODAL (TRANSCRIPCIÓN DEL VÍDEO EN DIRECTO) ===")

ruta_actual = os.path.dirname(os.path.abspath(__file__))
ruta_video = os.path.join(ruta_actual, 'partido.mp4')
ruta_audio_vosk = os.path.join(ruta_actual, 'audio_vosk.wav')

# --- 0. PREPARACIÓN DEL AUDIO PARA LA IA ---
if not os.path.exists(ruta_audio_vosk):
    print("0. Preparando pista de audio para la IA (Convirtiendo a 16kHz Mono)...")
    try:
        clip = VideoFileClip(ruta_video)
        # Vosk NECESITA estrictamente que el audio sea Mono y a 16000Hz
        clip.audio.write_audiofile(ruta_audio_vosk, fps=16000, nbytes=2, codec='pcm_s16le', ffmpeg_params=["-ac", "1"], logger=None)
        clip.close()
    except Exception as e:
        print(f"ERROR al extraer audio: {e}")
        exit()

# --- 1. CONFIGURACIÓN DEL HILO DE AUDIO (VOSK) ---
print("1. Cargando Cerebro Auditivo (Vosk Offline)...")
ruta_modelo_voz = os.path.join(ruta_actual, "modelo_voz_es")
if not os.path.exists(ruta_modelo_voz):
    print("ERROR FATAL: No encuentro la carpeta del modelo de voz 'modelo_voz_es'")
    exit()

modelo_vosk = Model(ruta_modelo_voz)
subtitulos_en_vivo = "Escuchando comentarista..." 

def hilo_escucha_virtual():
    """Hilo Fantasma: Lee el archivo .wav a la misma velocidad que el vídeo"""
    global subtitulos_en_vivo
    wf = wave.open(ruta_audio_vosk, "rb")
    reconocedor = KaldiRecognizer(modelo_vosk, wf.getframerate())
    
    # Esperamos a que el reproductor de música de pygame arranque
    while not pygame.mixer.get_init() or not pygame.mixer.music.get_busy():
        time.sleep(0.1)
        
    while pygame.mixer.music.get_busy():
        # Preguntamos al reloj por dónde va el audio que suena por el altavoz
        tiempo_actual_ms = pygame.mixer.music.get_pos()
        if tiempo_actual_ms < 0:
            continue
            
        # Calculamos cuántos frames del archivo debería haber escuchado la IA a estas alturas
        posicion_actual_frames = wf.tell()
        frame_objetivo = int((tiempo_actual_ms / 1000.0) * wf.getframerate())
        frames_a_leer = frame_objetivo - posicion_actual_frames
        
        # Si el audio avanza, le pasamos ese trocito nuevo a Vosk
        if frames_a_leer > 0:
            data = wf.readframes(frames_a_leer)
            if len(data) == 0: break
            
            if reconocedor.AcceptWaveform(data):
                # Frase terminada
                resultado = json.loads(reconocedor.Result())
                texto = resultado.get("text", "")
                if texto: subtitulos_en_vivo = texto
            else:
                # Frase a medias (tiempo real)
                parcial = json.loads(reconocedor.PartialResult())
                texto_parcial = parcial.get("partial", "")
                if texto_parcial:
                    palabras = texto_parcial.split()
                    subtitulos_en_vivo = " ".join(palabras[-8:]) # Mostramos las ultimas 8 palabras
        else:
            time.sleep(0.05)

# Arrancamos el Hilo Fantasma
hilo_audio = threading.Thread(target=hilo_escucha_virtual, daemon=True)
hilo_audio.start()

# --- 2. CONFIGURACIÓN DE VISIÓN E IA ---
print("2. Cargando Visión (YOLOv8) e IA (Random Forest)...")
modelo_yolo = YOLO('yolov8n.pt')
try:
    cerebro_ml = joblib.load(os.path.join(ruta_actual, 'cerebro_tipster.pkl'))
except:
    print("ERROR: No encuentro cerebro_tipster.pkl")
    exit()

# --- 3. BUCLE PRINCIPAL DE VÍDEO ---
cap = cv2.VideoCapture(ruta_video)
fps_video = cap.get(cv2.CAP_PROP_FPS) or 25.0 

print("¡SISTEMA LISTO! Escuchando al comentarista del partido...")

# Arrancamos el reproductor de sonido
pygame.mixer.init()
pygame.mixer.music.load(ruta_audio_vosk)
pygame.mixer.music.play()

tiempo_inicio = time.time()
frames_leidos = 0

while cap.isOpened() and pygame.mixer.music.get_busy():
    tiempo_video_actual = cap.get(cv2.CAP_PROP_POS_MSEC) / 1000.0
    tiempo_audio_actual = pygame.mixer.music.get_pos() / 1000.0

    # Motor de Sincronización
    if tiempo_video_actual > tiempo_audio_actual:
        espera = tiempo_video_actual - tiempo_audio_actual
        if espera > 0: time.sleep(espera)
    elif tiempo_audio_actual - tiempo_video_actual > 0.05: 
        ret, _ = cap.read()
        continue

    ret, frame = cap.read()
    if not ret: break 
    
    frame = cv2.resize(frame, (1280, 720))
    alto_frame, ancho_frame = frame.shape[:2]
    
    contador_barca = 0
    contador_madrid = 0
    suma_coordenadas_x = 0
    total_jugadores_detectados = 0
    
    # --- LA VISTA ---
    resultados = modelo_yolo(frame, classes=[0], conf=0.3, verbose=False)
    for caja in resultados[0].boxes:
        x1, y1, x2, y2 = map(int, caja.xyxy[0])
        recorte = frame[y1:y2, x1:x2]
        if recorte.size == 0: continue
            
        centro_x = (x1 + x2) / 2
        suma_coordenadas_x += centro_x
        total_jugadores_detectados += 1
            
        hsv = cv2.cvtColor(recorte, cv2.COLOR_BGR2HSV)
        mask_madrid = cv2.inRange(hsv, np.array([0, 0, 180]), np.array([180, 50, 255]))
        mask_barca = cv2.bitwise_or(
            cv2.inRange(hsv, np.array([90, 80, 50]), np.array([130, 255, 255])),
            cv2.bitwise_or(cv2.inRange(hsv, np.array([0, 80, 50]), np.array([10, 255, 255])),
                           cv2.inRange(hsv, np.array([160, 80, 50]), np.array([180, 255, 255])))
        )
        
        pixeles_madrid = cv2.countNonZero(mask_madrid)
        pixeles_barca = cv2.countNonZero(mask_barca)
        
        if pixeles_madrid > pixeles_barca and pixeles_madrid > 20:
            contador_madrid += 1
            cv2.rectangle(frame, (x1, y1), (x2, y2), (255, 255, 255), 2)
        elif pixeles_barca > pixeles_madrid and pixeles_barca > 20:
            contador_barca += 1
            cv2.rectangle(frame, (x1, y1), (x2, y2), (0, 0, 255), 2)
        else:
            cv2.rectangle(frame, (x1, y1), (x2, y2), (0, 255, 255), 1)

    # --- ANÁLISIS ESPACIAL ---
    zona_actual = "MEDIO CAMPO"
    if total_jugadores_detectados > 0:
        centro_gravedad_juego = suma_coordenadas_x / total_jugadores_detectados
        tercio = ancho_frame / 3
        if centro_gravedad_juego < tercio: zona_actual = "ZONA IZQUIERDA"
        elif centro_gravedad_juego > (2 * tercio): zona_actual = "ZONA DERECHA"

    # --- EL CEREBRO ---
    datos_entrada = pd.DataFrame([[contador_barca, contador_madrid]], columns=['Atacantes Barca', 'Defensas Madrid'])
    prediccion_raw = cerebro_ml.predict(datos_entrada)[0]
    
    decision_ml = "MANTENER"
    color_ml = (0, 255, 255)
    
    if "APOSTAR" in prediccion_raw:
        decision_ml = "APUESTA AL GOL"
        color_ml = (0, 255, 0)
    elif "ESPERAR" in prediccion_raw:
        decision_ml = "ESPERAR (Riesgo Numerico)"
        color_ml = (0, 165, 255)

    if decision_ml == "APUESTA AL GOL" and zona_actual == "MEDIO CAMPO":
        decision_ml = "ESPERAR (Accion Medio Campo)"
        color_ml = (0, 165, 255) 

    # --- LA FUSIÓN MULTIMODAL ---
    decision_final = decision_ml
    color_final = color_ml
    
    # Leemos la variable que la IA VOSK está escribiendo al escuchar el partido
    texto_comentarista = subtitulos_en_vivo.lower()
    
    palabras_alerta = ["gol", "peligro", "área", "castigar", "solo", "disparo", "atención"]
    if any(p in texto_comentarista for p in palabras_alerta):
        if decision_ml == "APUESTA AL GOL":
            decision_final = "MULTIMODAL: APUESTA SEGURA (100%)"
            color_final = (255, 0, 255) 
        else:
            decision_final = "ALERTA AUDIO: POSIBLE PELIGRO"
            color_final = (255, 0, 255) 
            
    # --- INTERFAZ GRÁFICA ---
    cv2.line(frame, (int(ancho_frame/3), 0), (int(ancho_frame/3), alto_frame), (255, 255, 255), 1)
    cv2.line(frame, (int(2*ancho_frame/3), 0), (int(2*ancho_frame/3), alto_frame), (255, 255, 255), 1)
    
    cv2.rectangle(frame, (0, 0), (550, 150), (0,0,0), -1)
    cv2.putText(frame, f"Atacantes Barca: {contador_barca}", (20, 40), cv2.FONT_HERSHEY_SIMPLEX, 0.8, (0, 0, 255), 2)
    cv2.putText(frame, f"Defensas Madrid: {contador_madrid}", (20, 80), cv2.FONT_HERSHEY_SIMPLEX, 0.8, (255, 255, 255), 2)
    cv2.putText(frame, f"ZONA DE ACCION: {zona_actual}", (20, 130), cv2.FONT_HERSHEY_SIMPLEX, 0.7, (0, 255, 255), 2)
    
    cv2.rectangle(frame, (0, alto_frame - 80), (ancho_frame, alto_frame), (0,0,0), -1) 
    cv2.putText(frame, f"AUDIO: '{texto_comentarista}'", (20, alto_frame - 50), cv2.FONT_HERSHEY_SIMPLEX, 0.7, (200, 200, 200), 2)
    cv2.putText(frame, f"IA: {decision_final}", (20, alto_frame - 15), cv2.FONT_HERSHEY_SIMPLEX, 0.9, color_final, 3)

    cv2.imshow('Smart Tipster AI - LIVE MULTIMODAL', frame) 
    
    if cv2.waitKey(1) & 0xFF == ord('q'):
        break

pygame.mixer.music.stop()
pygame.quit()
cap.release()
cv2.destroyAllWindows()
print("Demostración finalizada.")
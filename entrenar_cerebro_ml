import pandas as pd
from sklearn.model_selection import train_test_split
from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import accuracy_score
import joblib
import os
import warnings
warnings.filterwarnings('ignore') # Ocultar avisos innecesarios

print("=== INICIANDO MÓDULO DE APRENDIZAJE AUTOMÁTICO AVANZADO ===")

# Calculamos la ruta exacta donde está guardado este script
ruta_actual = os.path.dirname(os.path.abspath(__file__))
ruta_csv = os.path.join(ruta_actual, 'historial_tipster.csv')

# 1. CARGAMOS TUS DATOS DEL EXCEL
print(f"1. Leyendo el Track Record desde:\n   {ruta_csv}")
try:
    datos = pd.read_csv(ruta_csv)
except FileNotFoundError:
    print("ERROR: No encuentro el archivo historial_tipster.csv.")
    exit()

# 2. PREPARAMOS LOS DATOS
X = datos[['Atacantes Barca', 'Defensas Madrid']]
Y = datos['Decision IA']

X_train, X_test, y_train, y_test = train_test_split(X, Y, test_size=0.2, random_state=42)

# 3. ENTRENAMOS EL MODELO AVANZADO (Random Forest)
print("2. Entrenando el modelo RandomForest (Bosques Aleatorios)...")
modelo_rf = RandomForestClassifier(n_estimators=100, random_state=42)
modelo_rf.fit(X_train, y_train)

# 4. EXAMINAMOS A LA IA
predicciones = modelo_rf.predict(X_test)
precision = accuracy_score(y_test, predicciones)
print(f"\n   Precisión de la IA: {precision * 100:.2f}%")

# 5. GUARDAMOS EL CEREBRO PARA USARLO EN EL VÍDEO
ruta_guardado = os.path.join(ruta_actual, 'cerebro_tipster.pkl')
joblib.dump(modelo_rf, ruta_guardado)
print(f"\n3. Cerebro guardado con éxito en:\n   {ruta_guardado}")
print("\n¡El Cerebro Predictivo está listo para ser integrado!")